# Copy to maestro.env and fill in. maestro.env is git-ignored (see .dockerignore / add to .gitignore).
# These are consumed by application-prod.yml via ${...} placeholders.

# ---- External Postgres (required) ----
# Point at YOUR Postgres. Must be a real JDBC URL (NOT the jdbc:tc:... testcontainers URL).
MAESTRO_DB_URL=jdbc:postgresql://your-postgres-host:5432/maestro
MAESTRO_DB_USERNAME=maestro
MAESTRO_DB_PASSWORD=change-me

# ---- Cluster identity / sizing ----
MAESTRO_CLUSTER_NAME=prod
# Rule of thumb for N nodes (N>=3): MAX_GROUP_NUM = 3*N, PER_NODE = 5.
# Defaults below are for the 3-node compose file.
MAESTRO_MAX_GROUP_NUM=9
MAESTRO_MAX_GROUP_NUM_PER_NODE=5
