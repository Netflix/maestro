{
  "properties": {
    "owner": "tester",
    "run_strategy": "sequential"
  },
  "workflow": {
    "id": "sample-kubernetes-env-wf",
    "name": "Test kubernetes workflow with env data",
    "description": "This workflow runs a kubernetes job, which sets env data.",
    "steps": [
      {"step": {"id": "start", "type": "NoOp", "transition": {"successors": {"job1":  "true"}}}},
      {
        "step": {
          "id": "job1",
          "type": "kubernetes",
          "transition": {"successors": {"end": "foo != 'default'"}},
          "retry_policy": {
            "error_retry_limit": 0
          },
          "params": {
            "foo":  {
              "value": "default",
              "type":  "STRING"
            },
            "errorRetries": {
              "expression": "params.getFromStep('MAESTRO_STEP_ERROR_RETRIES')",
              "type":  "LONG"
            },
            "kubernetes": {
              "value": {
                "image": {
                  "value": "busybox",
                  "type": "STRING"
                },
                "env": {
                  "value": {
                    "error_retries": "${errorRetries}"
                  },
                  "type": "STRING_MAP"
                },
                "command": {
                  "value": ["/bin/sh"],
                  "type": "STRING_ARRAY"
                },
                "args": {
                  "value": ["-c", "echo error retries: $${error_retries} && echo $$MAESTRO_OUTPUT_START$1$$MAESTRO_OUTPUT_END", "sh", "{\"params\":{\"foo\": {\"value\":\"bar\",\"type\":\"STRING\",\"evaluated_result\":\"bar\",\"evaluated_time\":1625871404000}},\"artifacts\":{\"maestro_dynamic_output\": {\"signal_outputs\":[{\"value\":{\"name\":{\"value\":\"demo_table\",\"type\":\"STRING\"}},\"type\":\"MAP\",\"evaluated_result\":{\"name\":\"demo_table\"},\"evaluated_time\": 1625871404000}],\"type\":\"DYNAMIC_OUTPUT\"}}}"],
                  "type": "STRING_ARRAY"
                }
              },
              "type": "MAP"
            }
          }
        }
      },
      {"step": {"id": "end", "type": "NoOp"}}
    ]
  }
}
